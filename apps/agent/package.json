{
  "name": "@paycrawl/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "paycrawl": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
