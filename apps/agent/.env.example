# Store only in a local, uncommitted .env file. Never paste a key into source control.
PAYCRAWL_PAYER_PRIVATE_KEY=0x
# Comma-separated, pre-authorized publisher payout addresses. The CLI refuses
# every 402 challenge whose payTo is not on this allowlist.
PAYCRAWL_ALLOWED_PAY_TO=0x0000000000000000000000000000000000000000
